{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Asterion",
  "version": "0.1.2",
  "identifier": "com.devtochukwu.asterion",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Asterion",
        "width": 1200,
        "height": 820,
        "minWidth": 880,
        "minHeight": 600,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "category": "Education",
    "shortDescription": "Read web novels on the desktop",
    "longDescription": "Asterion is a local-first desktop reader for web novels, with an immersive reading experience, offline chapters, and reading-progress sync.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
