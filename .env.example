# Supabase project credentials (Project Settings -> API).
# The ANON key is safe to ship in the client; it is read-scoped by RLS.
# The service_role key must NEVER live here or in the app — it lives only on the
# VM running the scraper-service.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Public GCS bucket holding chapter text (content_path objects). The reader
# fetches chapters from https://storage.googleapis.com/<bucket>/<content_path>.
VITE_GCS_BUCKET=asterion-novels
